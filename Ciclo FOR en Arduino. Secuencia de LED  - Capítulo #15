int pinDigital1= 11;
int pinDigital2= 10;
int retardo = 1000;
int i;
int repeticionesAmarillo = 3;
int repeticionesVerde = 5;

void setup() {
  // put your setup code here, to run once:
  pinMode(pinDigital1,OUTPUT);
  pinMode(pinDigital2,OUTPUT);
}

void loop() {
  // put your main code here, to run repeatedly:
  for(i = 0;i<repeticionesAmarillo;i++){

  digitalWrite(pinDigital1,HIGH);
  delay(retardo);
  digitalWrite(pinDigital1,LOW);
  delay(retardo);

  }
  
  
  for(i = 0;i<repeticionesVerde;i++){

  digitalWrite(pinDigital2,HIGH);
  delay(retardo);
  digitalWrite(pinDigital2,LOW);
  delay(retardo);

  }

}
